      <aliases enabled='yes' />
      <column caption='Zero Discount Filter' datatype='boolean' name='[Calculation_0179509697257473]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Discount] = 0' />
      </column>
      <column caption='X-Axis: Product Running Pct' datatype='real' name='[Calculation_0221840973369348]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX() / SIZE()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Y-Axis: Sales Cumulative Pct' datatype='real' name='[Calculation_0221840973537285]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales])) / TOTAL(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='True Pareto Pinpoint' datatype='real' name='[Calculation_0221840973717510]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0221840973537285] &gt;= 0.80 &#13;&#10;AND [Calculation_0221840973369348] = WINDOW_MIN(IF [Calculation_0221840973537285] &gt;= 0.80 THEN [Calculation_0221840973369348] END)&#13;&#10;THEN [Calculation_0221840973537285]&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Months of latest year' datatype='datetime' name='[Calculation_0981052661641223]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF YEAR([Order Date]) = {MAX(YEAR([Order Date]))}&#13;&#10;THEN DATETRUNC(&apos;month&apos;, [Order Date])&#13;&#10;END' />
      </column>
      <column caption='Days to Ship' datatype='integer' name='[Calculation_0981052694704136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(DATEDIFF(&apos;day&apos;, [Order Date], [Ship Date]))' />
      </column>
      <column caption='Product Running Pct' datatype='real' name='[Calculation_1058568075554823]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()/SIZE()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sales Cumulative Percentage' datatype='real' name='[Calculation_1058568079036424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales])) / TOTAL(SUM([Sales]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='True Pareto Point' datatype='real' name='[Calculation_1058568079691785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1058568079036424] &gt;= 0.80 &#13;&#10;    AND [Calculation_1058568075554823] = WINDOW_MIN(IF [Calculation_1058568079036424] &gt;= 0.80 THEN [Calculation_1058568075554823] END)&#13;&#10;    THEN [Calculation_1058568079036424]&#13;&#10;    END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='product count' datatype='integer' name='[Calculation_1058568090566668]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INDEX()'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Customer Order Total' datatype='integer' name='[Calculation_1058568094236685]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{Fixed [Customer ID]: COUNTD([Order ID])}' />
      </column>
      <column caption='TRUE Average Order Value' datatype='real' name='[Calculation_1058568136519694]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / COUNTD([Order ID])' />
      </column>
      <column caption='Profit Ratio' datatype='real' default-format='p0.0%' name='[Calculation_1058568164085775]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit (Orders1)]) / SUM([Sales (Orders1)])' />
      </column>
      <column caption='Delivery Time (Days)' datatype='integer' name='[Calculation_1219647287771136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Order Date (Orders1)], [Ship Date (Orders1)])' />
      </column>
      <column caption='Profit Indicator' datatype='string' name='[Calculation_1339218122948613]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &lt; 0 THEN &quot;Negative&quot; ELSE &quot;Positive&quot; END' />
      </column>
      <column caption='LOD 3 months Moving Average' datatype='real' name='[Calculation_1418108908937216]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Step 1: Calculate the safe sum of the 3-month window&#13;&#10;(&#13;&#10;  ZN({FIXED [Calculation_1418108912316418] : SUM([Sales])}) +&#13;&#10;  &#13;&#10;  ZN({FIXED [Calculation_1418108912316418] : SUM(IF [Calculation_1418108912316418] = DATEADD(&apos;month&apos;, 1, [Calculation_1418108912316418]) THEN [Sales] END)}) +&#13;&#10;  &#13;&#10;  ZN({FIXED [Calculation_1418108912316418] : SUM(IF [Calculation_1418108912316418] = DATEADD(&apos;month&apos;, 2, [Calculation_1418108912316418]) THEN [Sales] END)})&#13;&#10;)&#13;&#10;/&#13;&#10;// Step 2: Dynamically divide by the number of active months found&#13;&#10;(&#13;&#10;  1 + &#13;&#10;  IF ISNULL({FIXED [Calculation_1418108912316418] : SUM(IF [Calculation_1418108912316418] = DATEADD(&apos;month&apos;, 1, [Calculation_1418108912316418]) THEN [Sales] END)}) THEN 0 ELSE 1 END +&#13;&#10;  IF ISNULL({FIXED [Calculation_1418108912316418] : SUM(IF [Calculation_1418108912316418] = DATEADD(&apos;month&apos;, 2, [Calculation_1418108912316418]) THEN [Sales] END)}) THEN 0 ELSE 1 END&#13;&#10;)' />
      </column>
      <column caption='Order Month Baseline' datatype='datetime' name='[Calculation_1418108912316418]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;, [Order Date])' />
      </column>
      <column caption='% of Total Sales' datatype='real' name='[Calculation_1425255003246593]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales]) / SUM({FIXED : SUM([Sales])})' />
      </column>
